*,
*::before,
*::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

:root {
  --blue-deep: #1b3a4f;
  --blue-main: #2a6b8a;
  --blue-mid: #4a95b5;
  --blue-light: #7cbad4;
  --blue-pale: #d0e8f2;
  --blue-wash: #e8f3f9;
  --cream: #f5f9fb;
  --warm: #f0ece4;
  --text: #263845;
  --text-sub: #5a7a8e;
  --accent: #c4785a;
  --accent-light: #e8a98a;
  --white: #ffffff;
  --radius: 10px;
  --radius-lg: 18px;
}

body {
  font-family: "Zen Kaku Gothic New", "Hiragino Sans", sans-serif;
  color: var(--text);
  background: var(--cream);
  font-weight: 400;
  line-height: 1.95;
  font-size: 15px;
  -webkit-font-smoothing: antialiased;
}

/* ── HEADER ── */
header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(245, 249, 251, 0.88);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(42, 107, 138, 0.08);
  padding: 0 2.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 60px;
}

.logo {
  font-family: "Noto Serif JP", serif;
  font-size: 1rem;
  font-weight: 500;
  color: var(--blue-deep);
  letter-spacing: 0.1em;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  text-decoration: none;
}

.logo-mark {
  width: 7px;
  height: 7px;
  background: var(--blue-main);
  border-radius: 50%;
}

nav {
  display: flex;
  gap: 2rem;
}

nav a {
  font-size: 0.78rem;
  color: var(--text-sub);
  text-decoration: none;
  letter-spacing: 0.06em;
  transition: color 0.25s;
  font-weight: 400;
}

nav a:hover {
  color: var(--blue-main);
}

/* ── PAGE HERO ── */
.page-hero {
  padding: 7.5rem 2rem 3.5rem;
  text-align: center;
  background: linear-gradient(175deg, #a8cedd 0%, #c4deea 40%, var(--cream) 100%);
  position: relative;
  overflow: hidden;
}

.page-hero::after {
  content: "";
  position: absolute;
  bottom: -1px;
  left: 0;
  right: 0;
  height: 60px;
  background: var(--cream);
  clip-path: ellipse(55% 100% at 50% 100%);
}

.hero-deco {
  position: absolute;
  border-radius: 50%;
  opacity: 0.07;
}

.hero-deco-1 {
  width: 400px;
  height: 400px;
  background: var(--blue-main);
  top: -120px;
  right: -80px;
}

.hero-deco-2 {
  width: 220px;
  height: 220px;
  background: var(--accent);
  bottom: 30px;
  left: -40px;
  opacity: 0.05;
}

.page-hero-label {
  font-size: 0.7rem;
  letter-spacing: 0.22em;
  color: var(--blue-main);
  display: inline-block;
  border: 1px solid rgba(42, 107, 138, 0.3);
  border-radius: 100px;
  padding: 0.25rem 1.2rem;
  margin-bottom: 1.5rem;
  position: relative;
  opacity: 0;
  animation: rise 0.7s 0.2s forwards;
}

.page-hero h1 {
  font-family: "Noto Serif JP", serif;
  font-size: clamp(2rem, 5.5vw, 4rem);
  font-weight: 300;
  color: var(--blue-deep);
  line-height: 1.4;
  letter-spacing: 0.06em;
  position: relative;
  opacity: 0;
  animation: rise 0.7s 0.35s forwards;
}

.page-hero-sub {
  font-size: 0.85rem;
  color: var(--text-sub);
  margin-top: 1rem;
  line-height: 2;
  position: relative;
  opacity: 0;
  animation: rise 0.7s 0.5s forwards;
}

@keyframes rise {
  from {
    opacity: 0;
    transform: translateY(16px);
  }
  to {
    opacity: 1;
    transform: none;
  }
}

/* ── SECTION COMMON ── */
section {
  padding: 5rem 2rem;
}

.inner {
  max-width: 860px;
  margin: 0 auto;
}

.sec-label {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.7rem;
  font-size: 0.68rem;
  letter-spacing: 0.22em;
  color: var(--blue-mid);
  margin-bottom: 1.2rem;
}

.sec-label::before,
.sec-label::after {
  content: "";
  flex: 1;
  max-width: 32px;
  height: 1px;
  background: var(--blue-light);
  opacity: 0.5;
}

.sec-title {
  font-family: "Noto Serif JP", serif;
  font-size: clamp(1.25rem, 2.5vw, 1.7rem);
  font-weight: 400;
  text-align: center;
  color: var(--blue-deep);
  line-height: 1.7;
  margin-bottom: 0.8rem;
}

.sec-desc {
  text-align: center;
  font-size: 0.85rem;
  color: var(--text-sub);
  max-width: 560px;
  margin: 0 auto 2.5rem;
  line-height: 2.1;
}

/* ── SECTION 1: GREETING ── */
.greeting {
  background: var(--cream);
}

.greeting-box {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 3rem;
  align-items: center;
  margin-top: 2rem;
}

.greeting-visual {
  position: relative;
}

.greeting-visual::before {
  content: "";
  position: absolute;
  top: -10px;
  left: -10px;
  width: 100%;
  height: 100%;
  border: 1px solid var(--blue-pale);
  border-radius: var(--radius-lg);
}

.greeting-img {
  width: 100%;
  aspect-ratio: 4/3;
  object-fit: cover;
  border-radius: var(--radius-lg);
  position: relative;
  z-index: 1;
  background: var(--blue-pale);
}

.greeting-body h3 {
  font-family: "Noto Serif JP", serif;
  font-size: 1.1rem;
  font-weight: 400;
  color: var(--blue-deep);
  margin-bottom: 1.2rem;
  line-height: 1.7;
}

.greeting-body p {
  font-size: 0.84rem;
  color: var(--text-sub);
  line-height: 2.2;
  margin-bottom: 0.8rem;
}

.greeting-sign {
  margin-top: 1.5rem;
  font-size: 0.78rem;
  color: var(--text-sub);
  text-align: right;
}

.greeting-sign span {
  font-family: "Noto Serif JP", serif;
  font-size: 0.9rem;
  color: var(--blue-deep);
  display: block;
  margin-top: 0.2rem;
}

/* ── SECTION 2: PHILOSOPHY ── */
.philosophy {
  background: linear-gradient(to bottom, var(--blue-wash), var(--cream));
  position: relative;
}

.philosophy::before {
  content: "";
  position: absolute;
  top: -1px;
  left: 0;
  right: 0;
  height: 60px;
  background: var(--cream);
  clip-path: ellipse(55% 100% at 50% 0%);
}

.phil-lead {
  text-align: center;
  font-size: 0.75rem;
  letter-spacing: 0.18em;
  color: var(--blue-mid);
  margin-bottom: 2rem;
}

.phil-message {
  max-width: 780px;
  margin: 0 auto;
  text-align: center;
}

.phil-message p.phil-catch {
  font-family: "Noto Serif JP", serif;
  font-size: clamp(1.8rem, 4vw, 3rem);
  font-weight: 300;
  color: var(--blue-deep);
  line-height: 1.4;
  letter-spacing: 0.05em;
  margin-bottom: 2.5rem;
}

.phil-message p {
  font-size: 0.88rem;
  color: var(--text-sub);
  line-height: 2.4;
  margin-bottom: 1.6rem;
}

.phil-message p:last-child {
  margin-bottom: 0;
}

/* ── SECTION 3: WORKS ── */
.works {
  background: var(--cream);
  padding-bottom: 5rem;
}

.tabs {
  display: flex;
  justify-content: center;
  gap: 0;
  background: var(--blue-pale);
  border-radius: 100px;
  padding: 4px;
  max-width: 340px;
  margin: 2.5rem auto 0;
}

.tab-btn {
  flex: 1;
  padding: 0.6rem 1.6rem;
  border: none;
  background: transparent;
  border-radius: 100px;
  font-family: "Zen Kaku Gothic New", sans-serif;
  font-size: 0.85rem;
  color: var(--text-sub);
  cursor: pointer;
  transition: all 0.3s ease;
  font-weight: 400;
  letter-spacing: 0.05em;
  white-space: nowrap;
}

.tab-btn.active {
  background: var(--white);
  color: var(--blue-deep);
  font-weight: 500;
  box-shadow: 0 2px 10px rgba(42, 107, 138, 0.12);
}

.tab-panel {
  display: none;
  margin-top: 3rem;
}

.tab-panel.active {
  display: block;
  animation: panelIn 0.45s ease;
}

@keyframes panelIn {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: none;
  }
}

.work-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2.8rem;
  align-items: center;
}

.work-img-wrap {
  border-radius: var(--radius-lg);
  overflow: hidden;
  position: relative;
}

.work-img-wrap::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: var(--radius-lg);
  box-shadow: inset 0 0 0 1px rgba(42, 107, 138, 0.08);
  pointer-events: none;
}

.work-img {
  width: 100%;
  aspect-ratio: 4/3;
  object-fit: cover;
  display: block;
  background: var(--blue-pale);
}

.work-cat {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.7rem;
  letter-spacing: 0.15em;
  color: var(--blue-main);
  background: var(--blue-wash);
  border-radius: 100px;
  padding: 0.3rem 1rem;
  margin-bottom: 0.8rem;
}

.work-cat-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--blue-main);
}

.work-info h3 {
  font-family: "Noto Serif JP", serif;
  font-size: 1.3rem;
  font-weight: 400;
  color: var(--blue-deep);
  margin-bottom: 0.8rem;
  line-height: 1.6;
}

.work-info > p {
  font-size: 0.84rem;
  color: var(--text-sub);
  line-height: 2.2;
  margin-bottom: 1.2rem;
}

.work-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.45rem;
}

.work-tag {
  font-size: 0.73rem;
  background: var(--blue-pale);
  color: var(--blue-deep);
  border-radius: 100px;
  padding: 0.28rem 0.85rem;
  letter-spacing: 0.03em;
}

.work-points {
  margin-top: 1.5rem;
  padding: 1.2rem 1.4rem;
  background: var(--blue-wash);
  border-radius: var(--radius);
}

.work-points-title {
  font-size: 0.72rem;
  font-weight: 500;
  color: var(--blue-main);
  letter-spacing: 0.08em;
  margin-bottom: 0.6rem;
}

.work-points-list {
  list-style: none;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.3rem 1.2rem;
}

.work-points-list li {
  font-size: 0.78rem;
  color: var(--text);
  display: flex;
  align-items: baseline;
  gap: 0.45rem;
  line-height: 1.8;
}

.work-points-list li::before {
  content: "";
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: var(--blue-mid);
  flex-shrink: 0;
  margin-top: 0.55em;
}

/* ── CTA BAND ── */
.cta-band {
  background: var(--blue-deep);
  padding: 3.5rem 2rem;
  text-align: center;
}

.cta-band h2 {
  font-family: "Noto Serif JP", serif;
  font-size: 1.2rem;
  font-weight: 400;
  color: #fff;
  margin-bottom: 0.8rem;
}

.cta-band p {
  font-size: 0.82rem;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 1.8rem;
  line-height: 2;
}

.cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: var(--white);
  color: var(--blue-deep);
  text-decoration: none;
  font-size: 0.82rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  padding: 0.8rem 2rem;
  border-radius: 100px;
  transition: transform 0.2s, box-shadow 0.2s;
}

.cta-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 24px rgba(0, 0, 0, 0.2);
}

.cta-btn svg {
  width: 14px;
  height: 14px;
}

/* ── FOOTER ── */
footer {
  background: #152d3d;
  color: rgba(255, 255, 255, 0.6);
  padding: 3rem 2rem;
  text-align: center;
}

.footer-logo {
  font-family: "Noto Serif JP", serif;
  font-size: 1rem;
  color: #fff;
  margin-bottom: 0.5rem;
  letter-spacing: 0.1em;
}

footer p {
  font-size: 0.76rem;
  line-height: 2;
}

.footer-copy {
  margin-top: 1.5rem;
  font-size: 0.7rem;
  opacity: 0.4;
}

/* ── WORKS BALLOON ── */
.works-balloon {
  text-align: center;
  margin-top: 3rem;
}

.balloon-btn {
  display: inline-block;
  position: relative;
  background: var(--blue-main);
  color: var(--white);
  text-decoration: none;
  font-size: 0.85rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  padding: 0.75rem 2rem;
  border-radius: 100px;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

/* 吹き出しの三角（上向き） */
.balloon-btn::before {
  content: "";
  position: absolute;
  top: -10px;
  left: 50%;
  transform: translateX(-50%);
  border: 6px solid transparent;
  border-bottom-color: var(--blue-main);
  border-top: none;
}

.balloon-btn:hover {
  transform: translateY(3px);
  box-shadow: 0 8px 24px rgba(42, 107, 138, 0.3);
}

/* ── SCROLL FADE ANIMATIONS ── */
.js-fade {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.65s ease, transform 0.65s ease;
}

.js-fade.js-fade--left  { transform: translateX(-32px); }
.js-fade.js-fade--right { transform: translateX(32px); }
.js-fade.is-visible     { opacity: 1; transform: none; }

/* ── HEADER SCROLL ── */
header {
  transition: background 0.3s, box-shadow 0.3s;
}

header.scrolled {
  background: rgba(245, 249, 251, 0.98);
  box-shadow: 0 2px 16px rgba(27, 58, 79, 0.08);
}

/* ── WORK IMAGE HOVER ZOOM ── */
.work-img-wrap a { display: block; }
.work-img {
  transition: transform 0.45s ease;
}

.work-img-wrap:hover .work-img {
  transform: scale(1.04);
}

/* ── RESPONSIVE ── */
@media (max-width: 720px) {
  header {
    padding: 0 1.2rem;
  }

  header nav {
    display: none;
  }

  section {
    padding: 3.5rem 1.2rem;
  }

  .greeting-box {
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .phil-values {
    grid-template-columns: 1fr;
  }

  .work-row {
    grid-template-columns: 1fr;
  }

  .work-points-list {
    grid-template-columns: 1fr;
  }
}
